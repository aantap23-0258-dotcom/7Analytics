;    #&quot;Removed Columns2&quot; = Table.RemoveColumns(#&quot;Renamed Columns&quot;,{&quot;Department and Region - Copy&quot;}),&#13;&#10;    #&quot;Renamed Columns1&quot; = Table.RenameColumns(#&quot;Removed Columns2&quot;,{{&quot;Name.1&quot;, &quot;First Name&quot;}, {&quot;Name.2&quot;, &quot;Last Name&quot;}, {&quot;Custom&quot;, &quot;Payment Type&quot;}}),&#13;&#10;    #&quot;Reordered Columns4&quot; = Table.ReorderColumns(#&quot;Renamed Columns1&quot;,{&quot;Order ID&quot;, &quot;Order Date&quot;, &quot;Arrival Date&quot;, &quot;Number of Days&quot;, &quot;First Name&quot;, &quot;Last Name&quot;, &quot;Department and Region&quot;, &quot;Payment Type&quot;, &quot;Revenue&quot;, &quot;Profit&quot;, &quot;Profit Margin&quot;}),&#13;&#10;    #&quot;Removed Duplicates&quot; = Table.Distinct(#&quot;Reordered Columns4&quot;, {&quot;Order ID&quot;}),&#13;&#10;    #&quot;Split Column by Delimiter2&quot; = Table.SplitColumn(#&quot;Removed Duplicates&quot;, &quot;Department and Region&quot;, Splitter.SplitTextByDelimiter(&quot;, &quot;, QuoteStyle.Csv), {&quot;Department and Region.1&quot;, &quot;Department and Region.2&quot;}),&#13;&#10;    #&quot;Changed Type5&quot; = Table.TransformColumnTypes(#&quot;Split Column by Delimiter2&quot;,{{&quot;Department and Region.1&quot;, type text}, {&quot;Department and Region.2&quot;, type text}}),&#13;&#10;    #&quot;Renamed Columns2&quot; = Table.RenameColumns(#&quot;Changed Type5&quot;,{{&quot;Department and Region.1&quot;, &quot;Department&quot;}, {&quot;Department and Region.2&quot;, &quot;Region&quot;}}),&#13;&#10;    #&quot;Removed Other Columns&quot; = Table.SelectColumns(#&quot;Renamed Columns2&quot;,{&quot;Region&quot;}),&#13;&#10;    #&quot;Removed Duplicates1&quot; = Table.Distinct(#&quot;Removed Other Columns&quot;),&#13;&#10;    #&quot;Sorted Rows&quot; = Table.Sort(#&quot;Removed Duplicates1&quot;,{{&quot;Region&quot;, Order.Ascending}}),&#13;&#10;    #&quot;Added Index&quot; = Table.AddIndexColumn(#&quot;Sorted R