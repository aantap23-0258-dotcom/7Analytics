<title>Query - program_dim</title>
<xml id=docprops><o:DocumentProperties
  xmlns:o="urn:schemas-microsoft-com:office:office"
  xmlns="http://www.w3.org/TR/REC-html40">
  <o:Description>Connection to the 'program_dim' query in the workbook.</o:Description>
  <o:Name>Query - program_dim</o:Name>
 </o:DocumentProperties>
</xml><xml id=msodc><odc:OfficeDataConnection
  xmlns:odc="urn:schemas-microsoft-com:office:odc"
  xmlns="http://www.w3.org/TR/REC-html40">
  <odc:PowerQueryConnection odc:Type="OLEDB">
   <odc:ConnectionString>Provider=Microsoft.Mashup.OleDb.1;Data Source=$Workbook$;Location=program_dim;Extended Properties=&quot;&quot;</odc:ConnectionString>
   <odc:CommandType>TableCollection</odc:CommandType>
   <odc:CommandText>&quot;program_dim&quot;</odc:CommandText>
  </odc:PowerQueryConnection>
  <odc:PowerQueryMashupData>&lt;Mashup xmlns:xsd=&quot;http://www.w3.org/2001/XMLSchema&quot; xmlns:xsi=&quot;http://www.w3.org/2001/XMLSchema-instance&quot; xmlns=&quot;http://schemas.microsoft.com/DataMashup&quot;&gt;&lt;Client&gt;EXCEL&lt;/Client&gt;&lt;Version&gt;2.150.1053.0&lt;/Version&gt;&lt;MinVersion&gt;2.21.0.0&lt;/MinVersion&gt;&lt;Culture&gt;en-PH&lt;/Culture&gt;&lt;SafeCombine&gt;true&lt;/SafeCombine&gt;&lt;Items&gt;&lt;Query Name=&quot;program_dim&quot;&gt;&lt;Formula&gt;&lt;![CDATA[let&#13;&#10;    Source = Excel.Workbook(File.Contents(&quot;C:\Users\COMLAB\Downloads\Student_Course_file.xlsx&quot;), null, true),&#13;&#10;    Student_Flat_Data_Sheet = Source{[Item=&quot;Student_Flat_Data&quot;,Kind=&quot;Sheet&quot;]}[Data],&#13;&#10;    #&quot;Promoted Headers&quot; = Table.PromoteHeaders(Student_Flat_Data_Sheet, [PromoteAllScalars=true]),&#13;&#10;    #&quot;Changed Type&quot; = Table.TransformColumnTypes(#&quot;Promoted Headers&quot;,{{&quot;StudentID&quot;, type text}, {&quot;StudentName&quot;, type text}, {&quot;Email&quot;, type text}, {&quot;Program&quot;, type text}, {&quot;YearLevel&quot;, Int64.Type}, {&quot;CourseCode&quot;, type text}, {&quot;CourseTitle&quot;, type text}, {&quot;Instructor&quot;, type text}, {&quot;InstructorEmail&quot;, type text}, {&quot;Room&quot;, type text}, {&quot;Schedule&quot;, type text}, {&quot;Grade&quot;, type text}}),&#13;&#10;    #&quot;Split Column by Delimiter&quot; = Table.SplitColumn(#&quot;Changed Type&quot;, &quot;StudentName&quot;, Splitter.SplitTextByDelimiter(&quot; &quot;, QuoteStyle.Csv), {&quot;StudentName.1&quot;, &quot;StudentName.2&quot;}),&#13;&#10;    #&quot;Changed Type1&quot; = Table.TransformColumnTypes(#&quot;Split Column by Delimiter&quot;,{{&quot;StudentName.1&quot;, type text}, {&quot;StudentName.2&quot;, type text}}),&#13;&#10;    #&quot;Renamed Columns&quot; = Table.RenameColumns(#&quot;Changed Type1&quot;,{{&quot;StudentName.1&quot;, &quot;First Name&quot;}, {&quot;StudentName.2&quot;, &quot;Last Name&quot;}}),&#13;&#10;    #&quot;Added Conditional Column&quot; = Table.AddColumn(#&quot;Renamed Columns&quot;, &quot;Year Label&quot;, each if [YearLevel] = 1 then &quot;Freshmen&quot; else if [YearLevel] = 2 then &quot;Sophomore&quot; else if [YearLevel] = 3 then &quot;Junior&quot; else &quot;Senior&quot;),&#13;&#10;    #&quot;Reordered Columns&quot; = Table.ReorderColumns(#&quot;Added Conditional Column&quot;,{&quot;StudentID&quot;, &quot;First Name&quot;, &quot;Last Name&quot;, &quot;Email&quot;, &quot;Program&quot;, &quot;YearLevel&quot;, &quot;Year Label&quot;, &quot;CourseCode&quot;, &quot;CourseTitle&quot;, &quot;Instructor&quot;, &quot;InstructorEmail&quot;, &quot;Room&quot;, &quot;Schedule&quot;, &quot;Grade&quot;}),&#13;&#10;    #&quot;Split Column by Character Transition&quot; = Table.SplitColumn(#&quot;Reordered Columns&quot;, &quot;CourseCode&quot;, Splitter.SplitTextByCharacterTransition((c) =&gt; not List.Contains({&quot;0&quot;..&quot;9&quot;}, c), {&quot;0&quot;..&quot;9&quot;}), {&quot;CourseCode.1&quot;, &quot;CourseCode.2&quot;}),&#13;&#10;    #&quot;Renamed Columns1&quot; = Table.RenameColumns(#&quot;Split Column by Character Transition&quot;,{{&quot;CourseCode.1&quot;, &quot;CourseCode&quot;}, {&quot;CourseCode.2&quot;, &quot;CourseNumber&quot;}}),&#13;&#10;    #&quot;Replaced Value&quot; = Table.ReplaceValue(#&quot;Renamed Columns1&quot;,&quot;@school.edu&quot;,&quot;cca.edu.ph&quot;,Replacer.ReplaceText,{&quot;Email&quot;}),&#13;&#10;    #&quot;Replaced Value1&quot; = Table.ReplaceValue(#&quot;Replaced Value&quot;,&quot;@school.edu&quot;,&quot;cca.edu.ph&quot;,Replacer.ReplaceText,{&quot;InstructorEmail&quot;}),&#13;&#10;    #&quot;Split Column by Delimiter1&quot; = Table.SplitColumn(#&quot;Replaced Value1&quot;, &quot;Schedule&quot;, Splitter.SplitTextByDelimiter(&quot; -&quot;, QuoteStyle.Csv), {&quot;Schedule.1&quot;, &quot;Schedule.2&quot;}),&#13;&#10;    #&quot;Split Column by Delimiter2&quot; = Table.SplitColumn(#&quot;Split Column by Delimiter1&quot;, &quot;Schedule.1&quot;, Splitter.SplitTextByDelimiter(&quot; &quot;, QuoteStyle.Csv), {&quot;Schedule.1.1&quot;, &quot;Schedule.1.2&quot;}),&#13;&#10;    #&quot;Changed Type2&quot; = Table.TransformColumnTypes(#&quot;Split Column by Delimiter2&quot;,{{&quot;CourseCode&quot;, type text}, {&quot;CourseNumber&quot;, Int64.Type}, {&quot;Schedule.1.1&quot;, type text}, {&quot;Schedule.1.2&quot;, type text}, {&quot;Schedule.2&quot;, type text}}),&#13;&#10;    #&quot;Split Column by Delimiter3&quot; = Table.SplitColumn(#&quot;Changed Type2&quot;, &quot;Schedule.1.2&quot;, Splitter.SplitTextByDelimiter(&quot;-&quot;, QuoteStyle.Csv), {&quot;Schedule.1.2.1&quot;, &quot;Schedule.1.2.2&quot;}),&#13;&#10;    #&quot;Changed Type3&quot; = Table.TransformColumnTypes(#&quot;Split Column by Delimiter3&quot;,{{&quot;Schedule.1.2.1&quot;, Int64.Type}, {&quot;Schedule.1.2.2&quot;, type time}}),&#13;&#10;    #&quot;Renamed Columns2&quot; = Table.RenameColumns(#&quot;Changed Type3&quot;,{{&quot;Schedule.1.1&quot;, &quot;Days&quot;}, {&quot;Schedule.1.2.1&quot;, &quot;Time Start&quot;}, {&quot;Schedule.1.2.2&quot;, &quot;Time End&quot;}}),&#13;&#10;    #&quot;Removed Columns&quot; = Table.RemoveColumns(#&quot;Renamed Columns2&quot;,{&quot;Schedule.2&quot;}),&#13;&#10;    #&quot;Added Conditional Column1&quot; = Table.AddColumn(#&quot;Removed Columns&quot;, &quot;''&quot;, each if [Time Start] = 1 then #time(13, 0, 0) else if [Time Start] = 9 then #time(9, 0, 0) else if [Time Start] = 10 then #time(10, 0, 0) else null),&#13;&#10;    #&quot;Reordered Columns1&quot; = Table.ReorderColumns(#&quot;Added Conditional Column1&quot;,{&quot;StudentID&quot;, &quot;First Name&quot;, &quot;Last Name&quot;, &quot;Email&quot;, &quot;Program&quot;, &quot;YearLevel&quot;, &quot;Year Label&quot;, &quot;CourseCode&quot;, &quot;CourseNumber&quot;, &quot;CourseTitle&quot;, &quot;Instructor&quot;, &quot;InstructorEmail&quot;, &quot;Room&quot;, &quot;Days&quot;, &quot;''&quot;, &quot;Time Start&quot;, &quot;Time End&quot;, &quot;Grade&quot;}),&#13;&#10;    #&quot;Removed Columns1&quot; = Table.RemoveColumns(#&quot;Reordered Columns1&quot;,{&quot;Time Start&quot;}),&#13;&#10;    #&quot;Renamed Columns3&quot; = Table.RenameColumns(#&quot;Removed Columns1&quot;,{{&quot;''&quot;, &quot;Time Start&quot;}}),&#13;&#10;    #&quot;Changed Type4&quot; = Table.TransformColumnTypes(#&quot;Renamed Columns3&quot;,{{&quot;Time Start&quot;, type time}, {&quot;Grade&quot;, type number}}),&#13;&#10;    #&quot;Removed Duplicates&quot; = Table.Distinct(#&quot;Changed Type4&quot;, {&quot;StudentID&quot;}),&#13;&#10;    #&quot;Removed Columns2&quot; = Table.RemoveColumns(#&quot;Removed Duplicates&quot;,{&quot;Time End&quot;, &quot;Time Start&quot;, &quot;Days&quot;, &quot;Room&quot;}),&#13;&#10;    #&quot;Removed Other Columns&quot; = Table.SelectColumns(#&quot;Removed Columns2&quot;,{&quot;Program&quot;}),&#13;&#10;    #&quot;Removed Duplicates1&quot; = Table.Distinct(#&quot;Removed Other Columns&quot;),&#13;&#10;    #&quot;Added Index&quot; = Table.AddIndexColumn(#&quot;Removed Duplicates1&quot;, &quot;Index&quot;, 101, 1, Int64.Type),&#13;&#10;    #&quot;Removed Columns3&quot; = Table.RemoveColumns(#&quot;Added Index&quot;,{&quot;Index&quot;}),&#13;&#10;    #&quot;Sorted Rows&quot; = Table.Sort(#&quot;Removed Columns3&quot;,{{&quot;Program&quot;, Order.Ascending}}),&#13;&#10;    #&quot;Added Index1&quot; = Table.AddIndexColumn(#&quot;Sorted Rows&quot;, &quot;Index&quot;, 101, 1, Int64.Type),&#13;&#10;    #&quot;Inserted Prefix&quot; = Table.AddColumn(#&quot;Added Index1&quot;, &quot;Prefix&quot;, each &quot;D-&quot; &amp; Text.From([Index], &quot;en-PH&quot;), type text),&#13;&#10;    #&quot;Removed Columns4&quot; = Table.RemoveColumns(#&quot;Inserted Prefix&quot;,{&quot;Index&quot;}),&#13;&#10;    #&quot;Renamed Columns4&quot; = Table.RenameColumns(#&quot;Removed Columns4&quot;,{{&quot;Prefix&quot;, &quot;Department_ID&quot;}}),&#13;&#10;    #&quot;Reordered Columns2&quot; = Table.ReorderColumns(#&quot;Renamed Columns4&quot;,{&quot;Department_ID&quot;, &quot;Program&quot;}),&#13;&#10;    #&quot;Renamed Columns5&quot; = Table.RenameColumns(#&quot;Reordered Columns2&quot;,{{&quot;Department_ID&quot;, &quot;Program_ID&quot;}})&#13;&#10;in&#13;&#10;    #&quot;Renamed Columns5&quot;]]&gt;&lt;/Formula&gt;&lt;IsParameterQuery xsi:nil=&quot;true&quot; /&gt;&lt;IsDirectQuery xsi:nil=&quot;true&quot; /&gt;&lt;/Query&gt;&lt;/Items&gt;&lt;/Mashup&gt;</odc:PowerQueryMashupData>
 </odc:OfficeDataConnection>
</xml>
